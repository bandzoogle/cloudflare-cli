#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

binary_name="${BINARY_NAME:-cfcli}"
output="${OUTPUT:-dist/$binary_name}"

echo "==> testing"
go test ./...

echo "==> building $output"
mkdir -p "$(dirname "$output")"
go build -trimpath -o "$output" .

echo "==> smoke testing"
"$output" --help >/dev/null
"$output" zones list --help >/dev/null
"$output" zones get --help >/dev/null
"$output" zones settings list --help >/dev/null
"$output" zones bot-management get --help >/dev/null
"$output" zones rulesets list --help >/dev/null
"$output" zones waf analytics --help >/dev/null
"$output" dns list --help >/dev/null
"$output" dns get --help >/dev/null
"$output" accounts list --help >/dev/null
"$output" accounts get --help >/dev/null
"$output" workers list --help >/dev/null
"$output" user whoami --help >/dev/null
"$output" scopes --help >/dev/null

echo "built $output"
